<article class="d5ecb__details" id="crafting-table-recipe-details-{{actor.id}}" aria-label="{{labels.recipeDetails}}">
  <button type="button" class="d5ecb__back" data-action="back-to-recipes">
    <i class="fas fa-arrow-left" aria-hidden="true"></i>
    {{labels.backToRecipes}}
  </button>
  <p class="d5ecb__busy-status" role="status" aria-live="polite" aria-atomic="true" data-crafting-busy-status {{#unless craftingInProgress}}hidden{{/unless}}>
    <i class="fas fa-spinner fa-spin" aria-hidden="true"></i>
    <span>{{labels.processingCraft}}</span>
  </p>
  {{#if selectedRecipe}}
    <header class="d5ecb__detail-header">
      <img src="{{selectedRecipe.img}}" alt="" />
      <div class="d5ecb__detail-heading">
        <h2>{{selectedRecipe.name}}</h2>
        <p>{{selectedRecipe.recipeTypeLabel}}</p>
      </div>
      <em class="d5ecb__status-pill {{selectedRecipe.statusClass}}"><i class="{{selectedRecipe.statusIconClass}}" aria-hidden="true"></i><span>{{selectedRecipe.statusLabel}}</span></em>
    </header>

    <div class="d5ecb__grid">
      <section class="d5ecb__status-card">
        <h3>{{labels.status}}</h3>
        <p class="d5ecb__status-summary" role="status" aria-live="polite" aria-atomic="true">{{selectedRecipe.statusSummary}}</p>
        <div class="d5ecb__meta-list">
          {{#each selectedRecipe.requirementChecklist}}
            <div class="d5ecb__row">
              <span>{{label}}</span>
              <strong>{{value}}</strong>
              <em class="{{stateClass}}">{{stateLabel}}</em>
            </div>
          {{/each}}
        </div>
        {{#if selectedRecipe.blockers.length}}
          <h4>{{labels.blockers}}</h4>
          <ul class="d5ecb__bullets">
            {{#each selectedRecipe.blockers}}<li>{{this}}</li>{{/each}}
          </ul>
        {{/if}}
        {{#if selectedRecipe.worldAdjustments.length}}
          <h4>{{labels.worldAdjustments}}</h4>
          <div class="d5ecb__adjustments">
            {{#each selectedRecipe.worldAdjustments}}<span>{{this}}</span>{{/each}}
          </div>
        {{/if}}
        <p class="d5ecb__hint"><strong>{{labels.nextStep}}:</strong> {{selectedRecipe.nextStep}}</p>
      </section>

      <section>
        <h3>{{labels.requirements}}</h3>
        <div class="d5ecb__row">
          <span>{{labels.requirementTool}}</span>
          <strong>{{selectedRecipe.toolName}}</strong>
          <em class="{{#if selectedRecipe.hasTool}}ok{{else}}bad{{/if}}">{{#if selectedRecipe.hasTool}}{{labels.ok}}{{else}}{{labels.missing}}{{/if}}</em>
        </div>
        {{#if selectedRecipe.proficiencyRequired}}
          <div class="d5ecb__row">
            <span>{{labels.requirementProficiency}}</span>
            <strong>{{labels.required}}</strong>
            <em class="{{#if selectedRecipe.hasProficiency}}ok{{else}}bad{{/if}}">{{#if selectedRecipe.hasProficiency}}{{labels.ok}}{{else}}{{labels.missing}}{{/if}}</em>
          </div>
        {{/if}}
      </section>

      <section>
        <h3>{{labels.craftingCheck}}</h3>
        <div class="d5ecb__check">
          <span>{{selectedRecipe.abilityLabel}}</span>
          <strong>{{labels.dc}} {{selectedRecipe.dc}}</strong>
        </div>
        {{#if selectedRecipe.hasAdjustedDc}}
          <p class="d5ecb__hint"><strong>{{labels.baseValue}}:</strong> {{labels.dc}} {{selectedRecipe.baseDc}}</p>
        {{/if}}
        <div class="d5ecb__row">
          <span>{{labels.craftingMode}}</span>
          <strong>{{selectedRecipe.effectiveModeLabel}}</strong>
          <em>{{selectedRecipe.effectiveModeSourceLabel}}</em>
        </div>
      </section>

      <section>
        <h3>{{labels.ingredients}}</h3>
        {{#each selectedRecipe.ingredients}}
          <div class="d5ecb__row">
            {{#if required}}
              <span>{{name}}</span>
            {{else}}
              <label class="d5ecb__optional-ingredient">
                <input type="checkbox" data-optional-ingredient-index="{{index}}" aria-label="{{../labels.useOptional}}: {{name}}" {{#if selected}}checked{{/if}} {{#if selectionDisabled}}disabled{{/if}} />
                <span>{{name}}</span>
              </label>
            {{/if}}
            <strong>{{owned}} / {{quantity}}{{#unless required}} ({{../labels.optional}}){{/unless}}</strong>
            <em class="{{statusClass}}">{{statusLabel}}</em>
          </div>
        {{/each}}
      </section>

      <section>
        <h3>{{labels.result}}</h3>
        {{#each selectedRecipe.results}}
          <div class="d5ecb__result">
            <img src="{{img}}" alt="" />
            <span><strong>{{name}}</strong><small>{{../labels.quantity}}: {{quantity}}</small></span>
          </div>
        {{/each}}
      </section>

      <section>
        <h3>{{labels.cost}}</h3>
        <p>{{selectedRecipe.costLabel}}</p>
        {{#if selectedRecipe.hasAdjustedCost}}
          <p class="d5ecb__hint"><strong>{{labels.baseValue}}:</strong> {{selectedRecipe.baseCostLabel}}</p>
        {{/if}}
      </section>

      <section>
        <h3>{{labels.time}}</h3>
        <p>{{selectedRecipe.timeLabel}}</p>
        {{#if selectedRecipe.hasAdjustedTime}}
          <p class="d5ecb__hint"><strong>{{labels.baseValue}}:</strong> {{selectedRecipe.baseTimeLabel}}</p>
        {{/if}}
      </section>

      <section class="d5ecb__progress">
        <h3>{{labels.progress}}</h3>
        {{#if selectedRecipe.requiresProgress}}
          <div class="d5ecb__progress-bar" role="progressbar" aria-label="{{labels.progress}}" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{selectedRecipe.progress.percent}}">
            <span style="width: {{selectedRecipe.progress.percent}}%"></span>
          </div>
          <p><strong>{{selectedRecipe.progress.percent}}%</strong> - {{selectedRecipe.progress.text}}</p>
          <p class="d5ecb__hint"><strong>{{labels.remaining}}:</strong> {{selectedRecipe.progress.remainingText}}</p>
          {{#unless selectedRecipe.progressComplete}}
            <label class="d5ecb__work-input">
              {{labels.workTime}}
              <input type="number" name="workHours" value="{{selectedRecipe.progress.defaultWorkHours}}" min="0.25" step="0.25" />
              <span>{{labels.hours}}</span>
            </label>
            <button type="button" class="d5ecb__work" data-action="work-craft" {{#unless selectedRecipe.canWork}}disabled{{/unless}}>{{selectedRecipe.workButtonLabel}}</button>
          {{else}}
            <p class="ok">{{labels.progressComplete}}</p>
            <button type="button" class="d5ecb__finish" data-action="finish-craft" {{#unless selectedRecipe.canCraft}}disabled{{/unless}}>{{selectedRecipe.finishButtonLabel}}</button>
          {{/unless}}
        {{else}}
          <p>{{labels.progressImmediate}}</p>
        {{/if}}
      </section>

      <section class="d5ecb__failure">
        <h3>{{labels.failure}}</h3>
        <p>{{selectedRecipe.failure}}</p>
      </section>
    </div>

    {{#if selectedRecipe.showCraftButton}}
      <footer class="d5ecb__footer">
        <button type="button" class="d5ecb__craft" data-action="craft" {{#unless selectedRecipe.canCraft}}disabled{{/unless}}>{{selectedRecipe.craftButtonLabel}}</button>
      </footer>
    {{/if}}
  {{else}}
    <div class="d5ecb__empty-state is-details" role="status">
      <i class="fas fa-scroll" aria-hidden="true"></i>
      <p>{{labels.selectRecipe}}</p>
    </div>
  {{/if}}
</article>
