<div class="ctgm__ingredient-row" data-ingredient-row data-editor-row>
  <div class="ctgm__row-order" aria-label="{{localize "CRAFTINGTABLE.GM.ReorderRow"}}">
    <button type="button" class="ctgm__drag-handle" draggable="true" data-row-drag-handle title="{{localize "CRAFTINGTABLE.GM.DragToReorder"}}" aria-label="{{localize "CRAFTINGTABLE.GM.DragToReorder"}}" {{#unless editable}}disabled{{/unless}}><i class="fas fa-grip-vertical" aria-hidden="true"></i></button>
    <button type="button" class="ctgm__row-move" data-action="move-row-up" title="{{localize "CRAFTINGTABLE.GM.MoveUp"}}" aria-label="{{localize "CRAFTINGTABLE.GM.MoveUp"}}" {{#unless editable}}disabled{{/unless}}><i class="fas fa-chevron-up" aria-hidden="true"></i></button>
    <button type="button" class="ctgm__row-move" data-action="move-row-down" title="{{localize "CRAFTINGTABLE.GM.MoveDown"}}" aria-label="{{localize "CRAFTINGTABLE.GM.MoveDown"}}" {{#unless editable}}disabled{{/unless}}><i class="fas fa-chevron-down" aria-hidden="true"></i></button>
  </div>
  <img class="ctgm__row-icon" src="{{img}}" alt="" />
  <label>
    {{localize "CRAFTINGTABLE.GM.Name"}}
    <input type="text" name="ingredient.name" value="{{name}}" placeholder="{{localize "CRAFTINGTABLE.GM.IngredientPlaceholder"}}" {{#unless editable}}readonly{{/unless}} />
  </label>
  <input type="hidden" name="ingredient.img" value="{{img}}" />
  <label data-advanced-field>
    {{localize "CRAFTINGTABLE.GM.UUID"}}
    <input type="text" name="ingredient.uuid" value="{{uuid}}" placeholder="Compendium.package.pack.Item.id" {{#unless editable}}readonly{{/unless}} />
  </label>
  <label>
    {{localize "CRAFTINGTABLE.GM.Quantity"}}
    <input type="number" name="ingredient.quantity" value="{{quantity}}" min="1" step="1" required {{#unless editable}}readonly{{/unless}} />
  </label>
  <label>
    {{localize "CRAFTINGTABLE.GM.Type"}}
    <select name="ingredient.type" {{#unless editable}}disabled{{/unless}}>
      {{#each typeOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
    </select>
  </label>
  <label class="ctgm__switch-line ctgm__ingredient-consumed">
    <span>{{localize "CRAFTINGTABLE.GM.Consumed"}}</span>
    <span class="ctgm__switch">
      <input type="checkbox" name="ingredient.consumed" aria-label="{{localize "CRAFTINGTABLE.GM.Consumed"}}" {{#if consumed}}checked{{/if}} {{#unless editable}}disabled{{/unless}} />
      <span></span>
    </span>
  </label>
  <label data-advanced-field>
    {{localize "CRAFTINGTABLE.GM.Match"}}
    <select name="ingredient.matchMode" {{#unless editable}}disabled{{/unless}}>
      {{#each matchModeOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
    </select>
  </label>
  <button type="button" class="ctgm__icon-action is-danger" data-action="remove-ingredient-row" title="{{localize "CRAFTINGTABLE.GM.RemoveIngredient"}}" aria-label="{{localize "CRAFTINGTABLE.GM.RemoveIngredient"}}" {{#unless editable}}disabled{{/unless}}><i class="fas fa-trash"></i></button>
</div>
